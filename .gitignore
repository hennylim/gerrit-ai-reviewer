# =============================================================================
# .gitignore — Gerrit AI 리뷰어
# =============================================================================

# ── 민감 설정 (절대 커밋 금지) ────────────────────────────────────────────────
.env
config/api_keys.json
config/reviewer_config.json

# ── 실행 결과 (공유 불필요) ────────────────────────────────────────────────────
output/
logs/
gerrit-ai-reviewer.log

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
.eggs/
*.egg-info/
dist/
build/

# ── 개발 도구 ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── 테스트 캐시 ──────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
