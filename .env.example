# =============================================================================
# .env.example — Gerrit AI 리뷰어 환경 변수 예시
# =============================================================================
# 복사 후 실제 값으로 수정:
#   cp .env.example .env
#   vi .env
#
# 사용 방법 (bash):
#   source .env && ./run_review.sh --change 12345 --patchset 1
#
# CI/CD 파이프라인에서는 환경 변수를 직접 주입하면 됩니다.
# (Jenkins: withCredentials, GitHub Actions: secrets, GitLab: CI variables)
# =============================================================================

# ── Gerrit 연결 설정 ─────────────────────────────────────────────────────────
export GERRIT_URL="https://gerrit.your-company.com"
export GERRIT_USER="ai-reviewer"
export GERRIT_PASSWORD="your-gerrit-http-password"

# ── AI 설정 ──────────────────────────────────────────────────────────────────
# 제공자: claude | gemini | openai
export AI_PROVIDER="gemini"
# 모델 미설정 시 각 제공자 기본값 사용
# export AI_MODEL="claude-sonnet-4-6"

# ── 실행 모드 제어 ────────────────────────────────────────────────────────────
# DRY-RUN: AI API 와 Gerrit 모두 실제 호출 안함 (true/false)
export REVIEWER_DRY_RUN="false"

# NO-POST: AI 리뷰는 수행하지만 Gerrit 에 등록 안함 (true/false)
export REVIEWER_NO_POST="false"

# VERBOSE: DEBUG 레벨 로그 출력 (true/false)
export REVIEWER_VERBOSE="false"

# ── Hook 전용 설정 ────────────────────────────────────────────────────────────
# 리뷰 대상 브랜치 필터 (공백 구분, 미설정 시 전체 브랜치)
# export REVIEWER_BRANCHES="main develop release"

# 건너뛸 Patchset 종류 (공백 구분)
export REVIEWER_SKIP_KINDS="TRIVIAL_REBASE NO_CODE_CHANGE"

# Python 경로 오버라이드 (미설정 시 자동 탐색)
# export REVIEWER_PYTHON="/usr/bin/python3.11"

# AI 제공자 Hook 오버라이드 (config 파일보다 우선)
# export REVIEWER_PROVIDER="gemini"
